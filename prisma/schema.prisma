// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. Admin
model Admin {
  id_admin Int    @id @default(autoincrement())
  username String @unique
  password String

  @@map("admin")
}

// 2. Kategori
model Kategori {
  id_kategori    Int     @id @default(autoincrement())
  label_kelas    String  @unique // Label dari YOLO (misal: 'plastic_bottle')
  nama_alias     String  // Nama tampilan (misal: 'Botol Plastik')
  jenis_material String  // Info material (misal: 'Plastik PET')
  
  // SAYA UBAH KE INT AGAR TIDAK ERROR DI NEXT.JS (Rupiah biasanya tidak pakai koma)
  nilai_jual     Int?    @default(0) 

  rekomendasi Rekomendasi?
  log_riwayat LogRiwayat[]

  @@map("kategori")
}

// 3. Rekomendasi
model Rekomendasi {
  id_rekomendasi Int    @id @default(autoincrement())
  isi_konten     String // Di Postgres otomatis jadi Text (Bisa panjang)

  id_kategori Int      @unique
  kategori    Kategori @relation(fields: [id_kategori], references: [id_kategori], onDelete: Cascade)

  @@map("rekomendasi")
}

// 4. Log_Riwayat
model LogRiwayat {
  id_riwayat    Int      @id @default(autoincrement())
  lokasi_gambar String   // URL gambar dari Supabase Storage
  skor_akurasi  Float    // Tipe Float standar (Double Precision)
  waktu_deteksi DateTime @default(now())
  
  // Tambahan info agar tidak perlu join tabel saat menampilkan list sederhana
  label_deteksi String?  

  id_kategori Int?     // Dibuat optional (Int?) jaga-jaga jika sampah tidak dikenali
  kategori    Kategori? @relation(fields: [id_kategori], references: [id_kategori])

  @@map("log_riwayat")
}